#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so the hook works when invoked via .git/hooks/ (where
# dirname/.. would otherwise resolve to .git instead of the repo root).
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

if [ "${QJS_SKIP_PRE_PUSH:-0}" = "1" ]; then
  echo "pre-push: skipped because QJS_SKIP_PRE_PUSH=1"
  exit 0
fi

echo "pre-push: full local gate..."
"$ROOT_DIR/scripts/check.sh"
